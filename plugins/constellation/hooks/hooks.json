{
	"version": 1,
	"hooks": {
		"sessionStart": [
			{
				"command": "node \"./hooks/inject.js\" sessionStart",
				"timeout": 10
			}
		],
		"subagentStart": [
			{
				"command": "node \"./hooks/inject.js\" subagentStart",
				"matcher": ".*",
				"timeout": 10
			}
		],
		"beforeMCPExecution": [
			{
				"command": "node \"./hooks/allow-constellation-mcp.js\"",
				"matcher": "constellation",
				"timeout": 5
			}
		],
		"preToolUse": [
			{
				"command": "node \"./hooks/pre-tool-steer.js\"",
				"matcher": "Shell|Grep|Glob",
				"timeout": 5
			}
		]
	}
}
